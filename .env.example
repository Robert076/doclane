# ---------- Database (local Postgres in compose) ----------
DB_NAME=doclane
DB_USER=robert
DB_PASSWORD=test

# ---------- AWS ----------
AWS_REGION=eu-west-1

# ---------- Cognito ----------
COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Same values, exposed to the browser bundle at build time.
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- S3 ----------
S3_BUCKET_NAME=doclane-documents

# ---------- App secrets ----------
SEED_SECRET=replace-me-with-a-32-byte-random-string
