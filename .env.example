# Copy this file to `.env` at the repo root and fill in the values.
# `.env` is git-ignored; this `.env.example` is committed.
#
# These are read by docker-compose.yml. Some are also read by the Go backend
# directly (when running outside compose, via `godotenv.Load("../../.env")`).

# ---------- Database (local Postgres in compose) ----------
DB_NAME=doclane
DB_USER=robert
DB_PASSWORD=test

# ---------- AWS ----------
AWS_REGION=eu-west-1

# ---------- Cognito ----------
# Use the dev client ID from aws/cognito.yml outputs (DoclaneDevUserPoolClientId),
# not the prod one — tokens minted with the prod client are rejected by anything
# that checks audience.
COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Same values, exposed to the browser bundle at build time.
NEXT_PUBLIC_COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- S3 ----------
# The real prod bucket is fine for local dev — uploads go to real S3.
S3_BUCKET_NAME=doclane-documents

# ---------- App secrets ----------
# Used by POST /api/auth/insert-admin. Generate with: openssl rand -base64 32
SEED_SECRET=replace-me-with-a-32-byte-random-string
