# syntax=docker/dockerfile:1.7

# ---------- Dependencies stage ----------
# Separate stage so the npm cache is reused across rebuilds when only source changes.
FROM node:22-alpine AS deps

WORKDIR /app

# Only copy the manifest files first; this layer is cached unless they change.
COPY package.json package-lock.json ./
RUN --mount=type=cache,target=/root/.npm \
    npm ci

# ---------- Build stage ----------
FROM node:22-alpine AS build

WORKDIR /app

# NEXT_PUBLIC_* values are inlined into the client bundle at build time, not runtime.
# We pass them in via build args so the same Dockerfile builds dev and prod images
# without code changes. They are not secrets — Cognito user pool / client IDs are
# public values exposed to the browser anyway.
ARG NEXT_PUBLIC_COGNITO_USER_POOL_ID
ARG NEXT_PUBLIC_COGNITO_CLIENT_ID
ARG NEXT_PUBLIC_BACKEND_URL
ENV NEXT_PUBLIC_COGNITO_USER_POOL_ID=${NEXT_PUBLIC_COGNITO_USER_POOL_ID} \
    NEXT_PUBLIC_COGNITO_CLIENT_ID=${NEXT_PUBLIC_COGNITO_CLIENT_ID} \
    NEXT_PUBLIC_BACKEND_URL=${NEXT_PUBLIC_BACKEND_URL} \
    NEXT_TELEMETRY_DISABLED=1

# Reuse the dependency tree from the deps stage.
COPY --from=deps /app/node_modules ./node_modules
COPY . .

RUN npm run build

# ---------- Runtime stage ----------
# Slim runtime that only contains what `next start` (via the standalone server) needs.
FROM node:22-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# Run as a non-root user. node:alpine ships a `node` user (uid 1000) we can reuse.
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nextjs -u 1001 -G nodejs

# Copy the standalone server bundle. This includes a trimmed node_modules.
COPY --from=build --chown=nextjs:nodejs /app/.next/standalone ./
# Static assets and public files are served directly by the standalone server.
COPY --from=build --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=build --chown=nextjs:nodejs /app/public ./public

USER nextjs

EXPOSE 3000

# server.js is generated by Next.js standalone output. It calls `next start` internally.
CMD ["node", "server.js"]
